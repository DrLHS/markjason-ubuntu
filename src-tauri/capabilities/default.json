{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/tmp/**" },
        { "path": "/mnt/**" },
        { "path": "/home/**" },
        { "path": "/root/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "C:/**" },
        { "path": "C:\\**" },
        { "path": "D:/**" },
        { "path": "D:\\**" },
        { "path": "E:/**" },
        { "path": "E:\\**" },
        { "path": "$RESOURCE/**" }
      ]
    },
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
